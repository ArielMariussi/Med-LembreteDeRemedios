@page "/"
@inherits HomePage
@inject IJSRuntime JS
<PageTitle>Home</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Meus Medicamentos</MudText>
<MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/medicines/create"
           StartIcon="@Icons.Material.Filled.Add" Class="mb-6">
    Novo Medicamento
</MudButton>

@if (!Medicines.Any())
{
    <MudAlert Severity="Severity.Info">Nenhum medicamento cadastrado.</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var med in Medicines)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <div class="d-flex justify-space-between align-center mb-2">
                            <MudText Typo="Typo.h6">@med.Name</MudText>
                            @if (med.Taken)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small"
                                         Icon="@Icons.Material.Filled.Check">
                                    Tomado
                                </MudChip>
                            }
                            else if (IsPastDue(med.Time))
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small"
                                         Icon="@Icons.Material.Filled.Warning">
                                    Atrasado
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small"
                                         Icon="@Icons.Material.Filled.Schedule">
                                    Pendente
                                </MudChip>
                            }
                        </div>

                        <div class="d-flex align-center gap-2 mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime"
                                     Size="Size.Small" Color="Color.Default" />
                            <MudText Typo="Typo.body1">@med.Time.ToString(@"hh\:mm")</MudText>
                        </div>
                    </MudCardContent>

                    <MudCardActions>
                        @if (!med.Taken)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.DoneAll"
                                       OnClick="() => MarkAsTaken(med.Id)"
                                       FullWidth="true">
                                Marcar como Tomado
                            </MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}
